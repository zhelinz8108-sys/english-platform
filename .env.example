NODE_ENV=development
WEB_ORIGIN=http://localhost:3000
WEB_PORT=3000
API_ORIGIN=http://localhost:4000
NEXT_PUBLIC_API_ORIGIN=http://localhost:4000

DATABASE_ADMIN_URL=postgresql://english_owner:english_owner@127.0.0.1:55432/english_platform
DATABASE_URL=postgresql://english_app:english_app@127.0.0.1:55432/english_platform
WORKER_DATABASE_URL=postgresql://english_worker:english_worker@127.0.0.1:55432/english_platform
DATABASE_POOL_MAX=20
DATABASE_STATEMENT_TIMEOUT_MS=15000
REDIS_URL=redis://127.0.0.1:6379

JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
COOKIE_SECURE=false
# 默认留空使用更安全的 host-only Cookie；只有明确的同站子域需求才配置。
COOKIE_DOMAIN=

S3_ENDPOINT=http://127.0.0.1:9000
# 容器部署时可设为浏览器可访问的外部地址；留空则使用 S3_ENDPOINT。
S3_PUBLIC_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=english-platform-private
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

SENTRY_DSN=
# OTLP 基础地址（API 会自动追加 /v1/traces）；也可改用 traces 专用完整地址。
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_SERVICE_NAME=english-platform-api
ENABLE_LOCAL_LISTENING=false
MINUTE_EARTH_SOURCE_DIR=
BBC_LISTENING_SOURCE_DIR=
ENABLE_LOCAL_READING=false
COMMONLIT_READING_SOURCE_DIR=
VOCABULARY_ASSESSMENT_SCORING_MODE=beta

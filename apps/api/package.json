{
  "name": "@english/api",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "import:minute-earth": "node scripts/import-minute-earth.mjs",
    "import:minute-earth-study-content": "node scripts/import-minute-earth-study-content.mjs",
    "simulate:vocabulary-assessment": "node scripts/simulate-vocabulary-assessment.mjs",
    "audit:vocabulary-bank": "node scripts/audit-vocabulary-bank.mjs",
    "generate:vocabulary-forms": "node scripts/generate-vocabulary-forms.mjs",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1085.0",
    "@aws-sdk/s3-request-presigner": "3.1085.0",
    "@english/database": "workspace:*",
    "@english/shared": "workspace:*",
    "@nestjs/common": "11.1.28",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-express": "11.1.28",
    "@node-rs/argon2": "2.0.2",
    "@opentelemetry/auto-instrumentations-node": "0.78.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.220.0",
    "@opentelemetry/resources": "2.9.0",
    "@opentelemetry/sdk-node": "0.220.0",
    "@opentelemetry/semantic-conventions": "1.43.0",
    "@sentry/node": "10.65.0",
    "cookie-parser": "1.4.7",
    "helmet": "8.2.0",
    "jose": "6.2.3",
    "kysely": "0.29.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "uuid": "14.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@nestjs/testing": "11.1.28",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "5.0.6",
    "@types/node": "26.1.1",
    "@types/supertest": "7.2.0",
    "supertest": "7.2.2",
    "tsx": "4.23.0",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}

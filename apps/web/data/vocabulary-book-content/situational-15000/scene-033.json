{"schemaVersion":1,"bookId":"situational-15000","unitId":"scene-033","title":"收发e-mail","sectionId":"chapter-02","sectionTitle":"日常交际你最强","pageStart":187,"pageEnd":191,"extractionMethod":"text-layer","wordEntryCount":22,"duplicateEntryCount":9,"pages":[{"number":187,"blocks":[{"type":"title","text":"33 收发e-mail"},{"type":"section","text":"Step1 场景词"},{"type":"entry","text":"mailbox [ˈmeɪlbɒks]","headword":"mailbox"},{"type":"definition","text":"n.信箱，邮箱"},{"type":"note","text":"◎electronic mailbox电子邮箱"},{"type":"entry","text":"absence of the recipent 无收件人","headword":"absence of the recipent"},{"type":"entry","text":"sender [ˈsendə(r)]","headword":"sender"},{"type":"definition","text":"n.发件人"}]},{"number":188,"blocks":[{"type":"entry","text":"uncertain [ʌnˈsɜːtn]","headword":"uncertain"},{"type":"definition","text":"a.不确定的；含糊的"},{"type":"note","text":"◎be uncertain about对…不确定"},{"type":"entry","text":"message area 信息区","headword":"message area"},{"type":"entry","text":"owe to 由于…","headword":"owe to"},{"type":"entry","text":"be grateful for 对…表示感激","headword":"be grateful for"},{"type":"entry","text":"make an apology 道歉","headword":"make an apology"},{"type":"entry","text":"no doubt 无疑地","headword":"no doubt"},{"type":"entry","text":"not to mention 不用提，更不用说","headword":"not to mention"},{"type":"entry","text":"faithfully [ˈfeɪθfəli]","headword":"faithfully"},{"type":"definition","text":"ad.忠诚地"},{"type":"note","text":"◎Yours faithfully（正式信函署名之前）您忠实的"},{"type":"entry","text":"sincerely [sɪnˈsɪəli]","headword":"sincerely"},{"type":"definition","text":"ad.真诚地"}]},{"number":189,"blocks":[{"type":"entry","text":"utmost [ˈʌtməʊst]","headword":"utmost"},{"type":"definition","text":"a.极度的"},{"type":"definition","text":"n.最大限度；极限"},{"type":"note","text":"◎utmost importance极其重要"},{"type":"entry","text":"send to 发送给","headword":"send to"},{"type":"text","text":"cc （carbon copy） [ˌsiː ˈsiː]"},{"type":"text","text":"abbr.抄送，副本"},{"type":"entry","text":"resend [riːˈsend]","headword":"resend"},{"type":"definition","text":"v.再发，重发"},{"type":"note","text":"◎resend the message重发信息"},{"type":"entry","text":"reply text 回复文本","headword":"reply text"},{"type":"entry","text":"netiquette [ˈnetɪket]","headword":"netiquette"},{"type":"definition","text":"n.网络礼节"},{"type":"entry","text":"spam [spæm]","headword":"spam"},{"type":"definition","text":"n.垃圾邮件"},{"type":"entry","text":"junk mail 垃圾邮件","headword":"junk mail"}]},{"number":190,"blocks":[{"type":"entry","text":"convenient [kənˈviːniənt]","headword":"convenient"},{"type":"definition","text":"a.方便的"},{"type":"note","text":"◎be convenient for便于…"},{"type":"entry","text":"speedy [ˈspiːdi]","headword":"speedy"},{"type":"definition","text":"a.快捷的"},{"type":"entry","text":"visual [ˈvɪʒuəl]","headword":"visual"},{"type":"definition","text":"a.视觉的"},{"type":"note","text":"◎visual effect视觉效果"},{"type":"section","text":"Step2 学以致用"},{"type":"section","text":"Conversation 1"},{"type":"example","text":"A：I send e-mails to myself as reminders. （为了备忘，我会给自己"},{"type":"text","text":"发邮件。）"},{"type":"example","text":"B：So do I. （我也是。）"},{"type":"section","text":"Conversation 2"},{"type":"example","text":"A：What's wrong with your e-mail box? Is it only for sending junk"},{"type":"text","text":"mails? （你的邮箱怎么回事？它只发垃圾邮件吗？）"}]},{"number":191,"blocks":[{"type":"example","text":"B：Sorry, I will check it now. （抱歉，我马上看一下。）"}]}]}
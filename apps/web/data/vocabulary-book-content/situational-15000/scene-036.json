{"schemaVersion":1,"bookId":"situational-15000","unitId":"scene-036","title":"感人心扉","sectionId":"chapter-02","sectionTitle":"日常交际你最强","pageStart":201,"pageEnd":204,"extractionMethod":"text-layer","wordEntryCount":18,"duplicateEntryCount":7,"pages":[{"number":201,"blocks":[{"type":"title","text":"36 感人心扉"},{"type":"section","text":"Step1 场景词"},{"type":"entry","text":"affecting [əˈfektɪŋ]","headword":"affecting"},{"type":"definition","text":"a.感人的，动人的"},{"type":"note","text":"◎affecting movie感人的电影"},{"type":"entry","text":"moving [ˈmuːvɪŋ]","headword":"moving"},{"type":"definition","text":"a.动人的，令人感动的"},{"type":"note","text":"◎a moving story一个感人的故事"},{"type":"entry","text":"moved [muːvd]","headword":"moved"},{"type":"definition","text":"a.感动的"},{"type":"note","text":"◎be moved by为…感动"},{"type":"entry","text":"heart-warming [ˈhɑːt wɔːmɪŋ]","headword":"heart-warming"},{"type":"definition","text":"a.温馨感人的，暖人心房的"},{"type":"note","text":"◎heart-warming project送温暖工程"},{"type":"entry","text":"good-hearted [ˌɡʊd ˈhɑːtɪd]","headword":"good-hearted"},{"type":"definition","text":"a.好心肠的，仁慈的，心地善良的"}]},{"number":202,"blocks":[{"type":"entry","text":"inspirational [ˌɪnspəˈreɪʃənl]","headword":"inspirational"},{"type":"definition","text":"a.鼓舞人心的"},{"type":"entry","text":"maternal love 母爱","headword":"maternal love"},{"type":"entry","text":"unconditional [ˌʌnkənˈdɪʃənl]","headword":"unconditional"},{"type":"definition","text":"a.无条件的"},{"type":"note","text":"◎unconditional support无条件支持"},{"type":"entry","text":"public welfare 公益（事业）","headword":"public welfare"},{"type":"entry","text":"mental strength 精神力量","headword":"mental strength"},{"type":"entry","text":"heartquake [ˈhɑːtkweɪk]","headword":"heartquake"},{"type":"definition","text":"n.震撼心灵"},{"type":"entry","text":"undying [ʌnˈdaɪɪŋ]","headword":"undying"},{"type":"definition","text":"a.永恒的，不朽的"}]},{"number":203,"blocks":[{"type":"entry","text":"impressible [ɪmˈpresəbl]","headword":"impressible"},{"type":"definition","text":"a.
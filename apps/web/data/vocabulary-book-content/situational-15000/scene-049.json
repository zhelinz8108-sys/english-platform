{"schemaVersion":1,"bookId":"situational-15000","unitId":"scene-049","title":"劝告告诫","sectionId":"chapter-02","sectionTitle":"日常交际你最强","pageStart":263,"pageEnd":267,"extractionMethod":"text-layer","wordEntryCount":22,"duplicateEntryCount":7,"pages":[{"number":263,"blocks":[{"type":"title","text":"49 劝告告诫"},{"type":"section","text":"Step1 场景词"},{"type":"entry","text":"persuade [pəˈsweɪd]","headword":"persuade"},{"type":"definition","text":"v.说服，劝说；使相信"},{"type":"note","text":"◎persuade sb. of使某人相信"},{"type":"entry","text":"persuasion [pəˈsweɪʒn]","headword":"persuasion"},{"type":"definition","text":"n.劝导，说服"},{"type":"note","text":"◎rational persuasion理性说服"},{"type":"text","text":"reason with sb. 与某人讲道理；规劝某人"},{"type":"entry","text":"counsel [ˈkaʊnsl]","headword":"counsel"},{"type":"definition","text":"n.忠告；建议；商议；法律顾问"},{"type":"definition","text":"v. 劝告；建议"},{"type":"note","text":"◎take counsel征求意见/legal counsel法律顾问"},{"type":"entry","text":"truth [truːθ]","headword":"truth"},{"type":"definition","text":"n.真理"}]},{"number":264,"blocks":[{"type":"note","text":"◎eternal truth永恒的真理"},{"type":"entry","text":"communicate [kəˈmjuːnɪkeɪt]","headword":"communicate"},{"type":"definition","text":"v.交流"},{"type":"note","text":"◎communicate with和…交流"},{"type":"entry","text":"make sense 讲得通","headword":"make sense"},{"type":"entry","text":"point of view 观点","headword":"point of view"},{"type":"entry","text":"comment on 对…发表意见","headword":"comment on"},{"type":"entry","text":"at the suggestion of 在…的建议下","headword":"at the suggestion of"},{"type":"entry","text":"ask for advice 征询意见","headword":"ask for advice"},{"type":"entry","text":"advise on 就…给出建议","headword":"advise on"},{"type":"entry","text":"cue [kjuː]","headword":"cue"},{"type":"definition","text":"n.提示，暗示；线索"},{"type":"note","text":"◎relevant cue关联线索"}]},{"number":265,"blocks":[{"type":"entry","text":"caution [ˈkɔːʃn]","headword":"caution"},{"type":"definition","text":"n.谨慎；警示，警告"},{"type":"note","text":"◎caution sign警告标志"},{"type":"entry","text":"warning [ˈwɔːnɪŋ]","headword":"warning"},{"type":"definition","text":"n.警告"},{"type":"note","text":"◎warning sign警告标志"},{"type":"entry","text":"preach to 告诫","headword":"preach to"},{"type":"entry","text":"disapprove [ˌdɪsəˈpruːv]","headword":"disapprove"},{"type":"definition","text":"v.不赞成"},{"type":"note","text":"◎totally disapprove完全不赞成"},{"type":"entry","text":"thinking [ˈθɪŋkɪŋ]","headword":"thinking"},{"type":"definition","text":"n.见解，想法；思维"},{"type":"note","text":"◎critical thinking批判性思维"},{"type":"entry","text":"viewpoint [ˈvjuːpɔɪnt]","headword":"viewpoint"},{"type":"definition","text":"n.观点，看法；视角"},{"type":"entry","text":"advisory [ədˈvaɪzəri]","headword":"advisory"},{"type":"definition","text":"a.顾问的，咨询的"},{"type":"note","text":"◎advisory opinion咨询意见"}]},{"number":266,"blocks":[{"type":"entry","text":"prevent [prɪˈvent]","headword":"prevent"},{"type":"definition","text":"v.预防；阻止"},{"type":"note","text":"◎prevent from阻止…"},{"type":"entry","text":"patient [ˈpeɪʃnt]","headword":"patient"},{"type":"definition","text":"a.耐心的"},{"type":"entry","text":"voice of opposition 反对的声音","headword":"voice of opposition"},{"type":"section","text":"Step2 学以致用"},{"type":"section","text":"Conversation 1"},{"type":"example","text":"A：I differed from her about this question. （在这个问题上，我和她"},{"type":"text","text":"意见不统一。）"},{"type":"example","text":"B：How did you persuade her? （你怎么说服她的？）"},{"type":"section","text":"Conversation 2"},{"type":"example","text":"A：I just don't think women belong in upper management. （我认为"},{"type":"text","text":"女人不该做高层管理工作。）"},{"type":"example","text":"B：I can't agree with your viewpoint.（我不同意你的观点。）"}]},{"number":267,"blocks":[{"type":"section","text":"Conversation 3"},{"type":"example","text":"A：Do you favour her proposition?（你赞成她的主张吗？）"},{"type":"example","text":"B：Of course. （当然。）"}]}]}
{"schemaVersion":1,"bookId":"situational-15000","unitId":"scene-087","title":"商品退换","sectionId":"chapter-04","sectionTitle":"商店购物买买买","pageStart":443,"pageEnd":447,"extractionMethod":"text-layer","wordEntryCount":25,"duplicateEntryCount":9,"pages":[{"number":443,"blocks":[{"type":"title","text":"87 商品退换"},{"type":"section","text":"Step1 场景词"},{"type":"entry","text":"return of goods 退货","headword":"return of goods"},{"type":"entry","text":"refundable [rɪˈfʌndəbl]","headword":"refundable"},{"type":"definition","text":"a.可退还的"},{"type":"note","text":"◎refundable deposit可退还的定金"},{"type":"entry","text":"return [rɪˈtɜːn]","headword":"return"},{"type":"definition","text":"v.返回"},{"type":"note","text":"◎return to回到/return commission回扣"},{"type":"entry","text":"sales return退货","headword":"sales return"},{"type":"entry","text":"complaint [kəmˈpleɪnt]","headword":"complaint"},{"type":"definition","text":"n.抱怨，投诉"},{"type":"note","text":"◎customer complaint客户投诉/complaint box 意见箱/complaint centre投"},{"type":"text","text":"诉中心"}]},{"number":444,"blocks":[{"type":"entry","text":"colour fading 褪色","headword":"colour fading"},{"type":"entry","text":"shrink in the wash 缩水","headword":"shrink in the wash"},{"type":"entry","text":"shoddy cotton黑心棉","headword":"shoddy cotton"},{"type":"entry","text":"expired [ɪkˈspaɪəd]","headword":"expired"},{"type":"definition","text":"a.到期的"},{"type":"note","text":"◎expired product过期产品"},{"type":"entry","text":"defective [dɪˈfektɪv]","headword":"defective"},{"type":"definition","text":"a.有缺陷的"},{"type":"note","text":"◎ defective goods残次品/defective product不合格产品"},{"type":"entry","text":"rough [rʌf]","headword":"rough"}]},{"number":445,"blocks":[{"type":"definition","text":"a.粗糙的"},{"type":"note","text":"◎rough machining粗加工"},{"type":"entry","text":"human factor 人为因素","headword":"human factor"},{"type":"entry","text":"overcharge [ˌəʊvəˈtʃɑːdʒ]","headword":"overcharge"},{"type":"definition","text":"v.要价过高"},{"type":"entry","text":"buyer show 买家秀","headword":"buyer show"},{"type":"entry","text":"replace [rɪˈpleɪs]","headword":"replace"},{"type":"definition","text":"v.更换，替换"},{"type":"note","text":"◎replace with替换为"},{"type":"entry","text":"pay extra money 额外加钱","headword":"pay extra money"},{"type":"entry","text":"punitive damage惩罚性赔偿","headword":"punitive damage"}]},{"number":446,"blocks":[{"type":"entry","text":"label [ˈleɪbl]","headword":"label"},{"type":"definition","text":"n.标签"},{"type":"note","text":"◎brand label品牌标签/adhesive label不干胶 标签/logo label牌号"},{"type":"entry","text":"price tag 价签","headword":"price tag"},{"type":"entry","text":"tear from 从…上撕下","headword":"tear from"},{"type":"entry","text":"troublesome [ˈtrʌblsəm]","headword":"troublesome"},{"type":"definition","text":"a.麻烦的"},{"type":"entry","text":"consumer rights 消费者权益","headword":"consumer rights"},{"type":"entry","text":"get money back 把钱要回来","headword":"get money back"},{"type":"entry","text":"application for drawback 申请退款","headword":"application for drawback"},{"type":"text","text":"negative comment/feedback 差评"},{"type":"entry","text":"favourable comment 好评","headword":"favourable comment"},{"type":"section","text":"Step2 学以致用"},{"type":"section","text":"Conversation 1"},{"type":"example","text":"A：Can I replace it if it doesn’t fit? （如果不合适的话，我能换货"},{"type":"text","text":"吗？）"},{"type":"example","text":"B：Within 14 days with the receipt. （14天内可以换货，要提供收"},{"type":"text","text":"据。）"}]},{"number":447,"blocks":[{"type":"section","text":"Conversation 2"},{"type":"example","text":"A：I want to give back this blouse and get my money back. （我想把"},{"type":"text","text":"这件衬衫退了，把钱拿回来。）"},{"type":"example","text":"B：OK, ma’am. May I ask what's wrong with it? （好的，女士。我"},{"type":"text","text":"能问一下这件衬衫有什么问题吗？）"}]}]}
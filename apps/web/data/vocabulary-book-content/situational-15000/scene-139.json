{"schemaVersion":1,"bookId":"situational-15000","unitId":"scene-139","title":"乐观积极","sectionId":"chapter-07","sectionTitle":"喜怒哀乐听你说","pageStart":704,"pageEnd":708,"extractionMethod":"text-layer","wordEntryCount":9,"duplicateEntryCount":24,"pages":[{"number":704,"blocks":[{"type":"title","text":"139 乐观积极"},{"type":"section","text":"Step1 场景词"}]},{"number":705,"blocks":[{"type":"entry","text":"alive [əˈlaɪv]","headword":"alive"},{"type":"definition","text":"a.有生气的；充满的"},{"type":"note","text":"◎alive with充满着"}]},{"number":706,"blocks":[]},{"number":707,"blocks":[{"type":"entry","text":"get-up-and-go [ˈɡet ʌp ən ˈɡəʊ]","headword":"get-up-and-go"},{"type":"definition","text":"a.积极的"},{"type":"entry","text":"willingly [ˈwɪlɪŋli]","headword":"willingly"},{"type":"definition","text":"ad. 愿意地"},{"type":"entry","text":"in the mood 兴致勃勃，兴高采烈","headword":"in the mood"},{"type":"entry","text":"be eager to 渴望做某事","headword":"be eager to"},{"type":"entry","text":"a keen interest 强烈的兴趣","headword":"a keen interest"},{"type":"entry","text":"vigor and vitality 生机与活力","headword":"vigor and vitality"},{"type":"entry","text":"give me five 击掌，加油","headword":"give me five"},{"type":"entry","text":"never give up easily 绝不轻易放弃","headword":"never give up easily"},{"type":"section","text":"Step2 学以致用"},{"type":"section","text":"Conversation 1"},{"type":"example","text":"A：He does everything with enthusiasm. （他做每件事都很有热"},{"type":"text","text":"情。）"},{"type":"example","text":"B：I appreciate that. （我很欣赏这一点。）"},{"type":"section","text":"Conversation 2"}]},{"number":708,"blocks":[{"type":"example","text":"A：I try really hard to be upbeat and positive. （我非常努力试着乐"},{"type":"text","text":"观积极。）"},{"type":"example","text":"B：That's good. Keep on.（那很好啊，坚持住。）"}]}]}
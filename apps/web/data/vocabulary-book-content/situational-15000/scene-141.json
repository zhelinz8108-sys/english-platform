{"schemaVersion":1,"bookId":"situational-15000","unitId":"scene-141","title":"欣赏赞扬","sectionId":"chapter-07","sectionTitle":"喜怒哀乐听你说","pageStart":714,"pageEnd":718,"extractionMethod":"text-layer","wordEntryCount":22,"duplicateEntryCount":21,"pages":[{"number":714,"blocks":[{"type":"title","text":"141 欣赏赞扬"},{"type":"section","text":"Step1 场景词"},{"type":"entry","text":"favour [ˈfeɪvə(r)]","headword":"favour"},{"type":"definition","text":"n./v.好感；赞同"},{"type":"note","text":"◎in favour of赞成"}]},{"number":715,"blocks":[{"type":"entry","text":"left-handed compliment言不由衷（或挖苦人）的恭维话","headword":"left-handed compliment"},{"type":"entry","text":"fondness [ˈfɒndnəs]","headword":"fondness"},{"type":"definition","text":"n.爱好，溺爱"},{"type":"note","text":"◎fondness for对…的喜爱"},{"type":"entry","text":"admirable [ˈædmərəbl]","headword":"admirable"},{"type":"definition","text":"a.值得赞扬的，令人钦佩的"},{"type":"entry","text":"new favourite新欢","headword":"new favourite"},{"type":"entry","text":"acclaimed [əˈkleɪmd]","headword":"acclaimed"},{"type":"definition","text":"a.受到赞扬的"},{"type":"note","text":"◎be acclaimed as被称誉为…"},{"type":"entry","text":"favourable [ˈfeɪvərəbl]","headword":"favourable"},{"type":"definition","text":"a.赞许的；有利的"},{"type":"note","text":"◎be favourable to对…有利"}]},{"number":716,"blocks":[{"type":"entry","text":"preferable [ˈprefrəbl]","headword":"preferable"},{"type":"definition","text":"a.更合意的"},{"type":"note","text":"◎be preferable to …更可取"},{"type":"entry","text":"flattered [ˈflætəd]","headword":"flattered"},{"type":"definition","text":"a.过分夸奖的"},{"type":"entry","text":"laudable [ˈlɔːdəbl]","headword":"laudable"},{"type":"definition","text":"a.值得赞美的，值得称赞的"},{"type":"entry","text":"admire [ədˈmaɪə(r)]","headword":"admire"},{"type":"definition","text":"v.钦佩，称赞"},{"type":"note","text":"◎admire for赞赏"}]},{"number":717,"blocks":[{"type":"entry","text":"congratulate [kənˈɡrætʃuleɪt]","headword":"congratulate"},{"type":"definition","text":"v.恭喜，庆贺"},{"type":"note","text":"◎congratulate on祝贺"},{"type":"entry","text":"congratulate oneself感到庆幸","headword":"congratulate oneself"},{"type":"entry","text":"bravo [ˌbrɑːˈvəʊ]","headword":"bravo"},{"type":"definition","text":"v.喝彩"},{"type":"text","text":"You look great! 你看起来很棒！"}]},{"number":718,"blocks":[{"type":"entry","text":"be proud of 为…感到骄傲","headword":"be proud of"},{"type":"entry","text":"be convinced 心悦诚服","headword":"be convinced"},{"type":"entry","text":"extremely admire 佩服得五体投地","headword":"extremely admire"},{"type":"entry","text":"strongly recommend 强力推荐","headword":"strongly recommend"},{"type":"entry","text":"have a good taste 有品位","headword":"have a good taste"},{"type":"entry","text":"win approval for 赞同","headword":"win approval for"},{"type":"entry","text":"a trustworthy friend 可信赖的朋友","headword":"a trustworthy friend"},{"type":"entry","text":"great personality 伟大人格","headword":"great personality"},{"type":"section","text":"Step2 学以致用"},{"type":"section","text":"Conversation 1"},{"type":"example","text":"A：I truly appreciate your kindness. （我很欣赏你的仁慈。）"},{"type":"example","text":"B：Thanks for the compliment.（承蒙夸奖。）"},{"type":"section","text":"Conversation 2"},{"type":"example","text":"A：Even though we don't get along, I admire my father. （尽管我们"},{"type":"text","text":"相处不好，但我敬佩我的父亲。）"},{"type":"example","text":"B：That's interesting.（很有意思。）"}]}]}
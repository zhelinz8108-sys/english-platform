{"schemaVersion":1,"bookId":"situational-15000","unitId":"scene-150","title":"不满抱怨","sectionId":"chapter-07","sectionTitle":"喜怒哀乐听你说","pageStart":757,"pageEnd":761,"extractionMethod":"text-layer","wordEntryCount":24,"duplicateEntryCount":19,"pages":[{"number":757,"blocks":[{"type":"title","text":"150 不满抱怨"},{"type":"section","text":"Step1 场景词"},{"type":"entry","text":"dissatisfaction [ˌdɪsˌsætɪsˈfækʃn]","headword":"dissatisfaction"},{"type":"definition","text":"n.不满"},{"type":"note","text":"◎express dissatisfaction表达不满"},{"type":"entry","text":"disapproval [ˌdɪsəˈpruːvl]","headword":"disapproval"},{"type":"definition","text":"n.不赞成，不喜欢"},{"type":"note","text":"◎with disapproval不满地"}]},{"number":758,"blocks":[{"type":"entry","text":"unacceptable [ˌʌnəkˈseptəbl]","headword":"unacceptable"},{"type":"definition","text":"a.无法接受的"},{"type":"entry","text":"terrible [ˈterəbl]","headword":"terrible"},{"type":"definition","text":"a.很糟的"},{"type":"entry","text":"awful [ˈɔːfl]","headword":"awful"},{"type":"definition","text":"a.糟糕的"},{"type":"entry","text":"dreadful [ˈdredfl]","headword":"dreadful"},{"type":"definition","text":"a.糟透的"},{"type":"entry","text":"dissatisfied [dɪsˈsætɪsfaɪd]","headword":"dissatisfied"},{"type":"definition","text":"a.不满意的；不满足的"},{"type":"note","text":"◎be dissatisfied with对…不满"},{"type":"entry","text":"discontented [ˌdɪskənˈtentɪd]","headword":"discontented"},{"type":"definition","text":"a.不满的"},{"type":"note","text":"◎be discontented with对…不满"}]},{"number":759,"blocks":[{"type":"entry","text":"complain [kəmˈpleɪn]","headword":"complain"},{"type":"definition","text":"v.抱怨；投诉"},{"type":"note","text":"◎complain about抱怨"}]},{"number":760,"blocks":[{"type":"entry","text":"blame [bleɪm]","headword":"blame"},{"type":"definition","text":"v.责怪，责备"},{"type":"note","text":"◎blame for责备"},{"type":"entry","text":"scold [skəʊld]","headword":"scold"},{"type":"definition","text":"v.责骂，斥责"},{"type":"entry","text":"can't bear 受够了","headword":"can't bear"},{"type":"entry","text":"can't put up with 无法忍受","headword":"can't put up with"},{"type":"entry","text":"not enough 不足","headword":"not enough"},{"type":"entry","text":"leave a lot to be desired 有许多待完善的地方","headword":"leave a lot to be desired"}]},{"number":761,"blocks":[{"type":"entry","text":"don't fit the bill 不符合要求","headword":"don't fit the bill"},{"type":"entry","text":"not be up to par 不够格","headword":"not be up to par"},{"type":"entry","text":"pretty bad 相当差","headword":"pretty bad"},{"type":"entry","text":"not fair 不公平","headword":"not fair"},{"type":"entry","text":"play fair 公平点","headword":"play fair"},{"type":"entry","text":"anything wrong 任何令人不满之事","headword":"anything wrong"},{"type":"entry","text":"not that great 不怎么样","headword":"not that great"},{"type":"entry","text":"no good at all 一点也不好","headword":"no good at all"},{"type":"entry","text":"all talk and no action 光说不做","headword":"all talk and no action"},{"type":"section","text":"Step2 学以致用"},{"type":"section","text":"Conversation 1"},{"type":"example","text":"A：I have nothing to grumble about.（我没有什么可抱怨的。）"},{"type":"example","text":"B：So you are content with your life. （这么说你对生活很满意。）"},{"type":"section","text":"Conversation 2"},{"type":"example","text":"A：Look, I'm not asking you to set me up.（瞧，我可没要你给我介"},{"type":"text","text":"绍对象。）"},{"type":"example","text":"B：But you come here and complain about being single all the time!"},{"type":"text","text":"（但你总是跑过来抱怨你的单身生活！）"}]}]}
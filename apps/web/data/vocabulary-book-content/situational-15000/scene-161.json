{"schemaVersion":1,"bookId":"situational-15000","unitId":"scene-161","title":"遵守校纪","sectionId":"chapter-08","sectionTitle":"青春校园当难忘","pageStart":811,"pageEnd":815,"extractionMethod":"text-layer","wordEntryCount":23,"duplicateEntryCount":14,"pages":[{"number":811,"blocks":[{"type":"title","text":"161 遵守校纪"},{"type":"section","text":"Step1 场景词"},{"type":"entry","text":"intellectual discipline知识学科","headword":"intellectual discipline"},{"type":"entry","text":"school discipline 校纪","headword":"school discipline"},{"type":"entry","text":"rule [ruːl]","headword":"rule"},{"type":"definition","text":"n.规则"},{"type":"note","text":"◎basic rule基本规则/follow the rule遵守规则"},{"type":"entry","text":"class regulation 班规","headword":"class regulation"},{"type":"entry","text":"attend class 上课","headword":"attend class"},{"type":"entry","text":"attendance record 考勤记录","headword":"attendance record"},{"type":"entry","text":"punctuality [ˌpʌŋktʃuˈæləti]","headword":"punctuality"},{"type":"definition","text":"n.准时"}]},{"number":812,"blocks":[{"type":"entry","text":"never cut in line 永远不要插队","headword":"never cut in line"},{"type":"entry","text":"ask for leave 请假","headword":"ask for leave"},{"type":"entry","text":"late for school 迟到","headword":"late for school"},{"type":"entry","text":"play truant 逃学","headword":"play truant"},{"type":"entry","text":"skip class 翘课","headword":"skip class"},{"type":"entry","text":"talk in class 上课说话","headword":"talk in class"},{"type":"entry","text":"plagiarise [ˈpleɪdʒəraɪz]","headword":"plagiarise"},{"type":"definition","text":"v.剽窃，抄袭"},{"type":"note","text":"◎plagiarise paper抄袭论文"},{"type":"entry","text":"academic dishonesty 学术欺诈","headword":"academic dishonesty"},{"type":"entry","text":"observe [əbˈzɜːv]","headword":"observe"},{"type":"definition","text":"v.遵守（法律、协议或习俗）"},{"type":"note","text":"◎observe the discipline遵守纪律"},{"type":"entry","text":"obey [əˈbeɪ]","headword":"obey"},{"type":"definition","text":"v.服从（权威），遵守（法规）"}]},{"number":813,"blocks":[{"type":"note","text":"◎obey the rule遵守规则"},{"type":"entry","text":"without permission 未经许可","headword":"without permission"},{"type":"entry","text":"corporal punishment 体罚","headword":"corporal punishment"},{"type":"entry","text":"record a demerit 记过","headword":"record a demerit"}]},{"number":814,"blocks":[{"type":"entry","text":"administrate [ədˈmɪnɪstreɪt]","headword":"administrate"},{"type":"definition","text":"v.管理；实施"},{"type":"entry","text":"propose a new regulation 提出新的规定","headword":"propose a new regulation"},{"type":"entry","text":"be bound to 必然，一定要…","headword":"be bound to"},{"type":"section","text":"Step2 学以致用"},{"type":"section","text":"Conversation 1"},{"type":"example","text":"A：How do you think about these regulations? （你觉得这些规定怎"},{"type":"text","text":"么样？）"},{"type":"example","text":"B：They are simple, but must be conformed with. （这些规定很简"},{"type":"text","text":"单，但必须遵守。）"}]},{"number":815,"blocks":[{"type":"section","text":"Conversation 2"},{"type":"example","text":"A：Please tell all faculties to attend the meeting. （请告知全体教员"},{"type":"text","text":"参加会议。）"},{"type":"example","text":"B：OK, I will send them an e-mail. （没问题，我会给他们发邮"},{"type":"text","text":"件。）"}]}]}
{"schemaVersion":1,"bookId":"situational-15000","unitId":"scene-245","title":"登山露营","sectionId":"chapter-11","sectionTitle":"运动文艺爱好广","pageStart":1206,"pageEnd":1210,"extractionMethod":"text-layer","wordEntryCount":23,"duplicateEntryCount":11,"pages":[{"number":1206,"blocks":[{"type":"title","text":"245 登山露营"},{"type":"section","text":"Step1 场景词"},{"type":"entry","text":"mountaineering [ˌmaʊntəˈnɪərɪŋ]","headword":"mountaineering"},{"type":"definition","text":"n.登山"},{"type":"note","text":"◎mountaineering bag登山包"},{"type":"entry","text":"climbing boots 登山靴","headword":"climbing boots"},{"type":"entry","text":"trekking pole 登山杖","headword":"trekking pole"},{"type":"entry","text":"camping [ˈkæmpɪŋ]","headword":"camping"},{"type":"definition","text":"n.露营，野营"},{"type":"note","text":"◎go camping去野营"},{"type":"entry","text":"campground [ˈkæmpɡraʊnd]","headword":"campground"},{"type":"definition","text":"n.露营地"},{"type":"note","text":"◎auto campground汽车营地"},{"type":"entry","text":"camper [ˈkæmpə(r)]","headword":"camper"},{"type":"definition","text":"n.露营者"},{"type":"text","text":"RV （Recreational Vehicle） [ˌɑː ˈviː]"},{"type":"text","text":"abbr.野营旅游车"},{"type":"entry","text":"tent [tent]","headword":"tent"}]},{"number":1207,"blocks":[{"type":"definition","text":"n.帐篷"},{"type":"entry","text":"camping gear 露营用具","headword":"camping gear"},{"type":"entry","text":"air mattress 充气床垫","headword":"air mattress"},{"type":"entry","text":"stuff bag 整理袋","headword":"stuff bag"},{"type":"entry","text":"sleeping bag 睡袋","headword":"sleeping bag"},{"type":"entry","text":"compass needle罗盘针","headword":"compass needle"},{"type":"entry","text":"satellite navigation卫星导航","headword":"satellite navigation"},{"type":"entry","text":"signal [ˈsɪɡnəl]","headword":"signal"},{"type":"definition","text":"n.信号"},{"type":"note","text":"◎signal light信号灯"},{"type":"entry","text":"thermos flask 热水瓶","headword":"thermos flask"}]},{"number":1208,"blocks":[{"type":"entry","text":"hard tack 压缩饼干","headwor
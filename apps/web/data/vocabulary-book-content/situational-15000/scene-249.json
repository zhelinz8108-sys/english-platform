{"schemaVersion":1,"bookId":"situational-15000","unitId":"scene-249","title":"古典乐与古典乐器","sectionId":"chapter-11","sectionTitle":"运动文艺爱好广","pageStart":1228,"pageEnd":1231,"extractionMethod":"text-layer","wordEntryCount":18,"duplicateEntryCount":18,"pages":[{"number":1228,"blocks":[{"type":"title","text":"249 古典乐与古典乐器"},{"type":"section","text":"Step1 场景词"},{"type":"entry","text":"eight sounds 八音","headword":"eight sounds"},{"type":"entry","text":"plucked string instrument 拨弦乐器","headword":"plucked string instrument"},{"type":"entry","text":"zither [ˈzɪðə(r)]","headword":"zither"},{"type":"definition","text":"n.古筝"},{"type":"entry","text":"bowed string instrument 弓弦乐器","headword":"bowed string instrument"},{"type":"entry","text":"Chinese lute 琵琶","headword":"Chinese lute"},{"type":"entry","text":"erhu [ˈɜːhuː]","headword":"erhu"},{"type":"definition","text":"n.二胡"}]},{"number":1229,"blocks":[{"type":"entry","text":"wind instrument 吹奏乐器","headword":"wind instrument"},{"type":"entry","text":"cymbal [ˈsɪmbl]","headword":"cymbal"},{"type":"definition","text":"n.钹"},{"type":"entry","text":"stone chime 石磬","headword":"stone chime"},{"type":"entry","text":"bronze chime 青铜编钟","headword":"bronze chime"},{"type":"entry","text":"Chinese gong 锣","headword":"Chinese gong"},{"type":"entry","text":"fou [fuː]","headword":"fou"},{"type":"definition","text":"n.缶"},{"type":"entry","text":"cucurbit flute 葫芦丝","headword":"cucurbit flute"},{"type":"entry","text":"vertical bamboo flute 萧","headword":"vertical bamboo flute"},{"type":"entry","text":"hole [həʊl]","headword":"hole"},{"type":"definition","text":"n.孔"}]},{"number":1230,"blocks":[{"type":"entry","text":"film hole 气膜孔","headword":"film hole"},{"type":"entry","text":"finger hole 指孔","headword":"finger hole"},{"type":"entry","text":"symphonic poem 交响诗","headword":"symphonic poem"}]},{"number":1231,"blocks":[{"type":"section","text":"Step2 学以致用"},{"type":"section","text":"Conversation 1"},{"type":"example","text":"A：I like that zither. It sounds good.（我喜欢那把古筝，听起来音"},{"type":"text","text":"质很好。）"},{"type":"example","text":"B：Yeah, it really does. I wish I knew how to play. （是的，的确音"},{"type":"text","text":"质很好。真希望我会弹。）"},{"type":"section","text":"Conversation 2"},{"type":"example","text":"A：What kind of instrument can you play?（你会演奏什么乐器？）"},{"type":"example","text":"B：I play the flute.（我会吹长笛。）"}]}]}
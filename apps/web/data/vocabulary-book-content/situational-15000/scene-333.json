{"schemaVersion":1,"bookId":"situational-15000","unitId":"scene-333","title":"巧应竞争对手","sectionId":"chapter-15","sectionTitle":"商务经济全在行","pageStart":1623,"pageEnd":1627,"extractionMethod":"text-layer","wordEntryCount":17,"duplicateEntryCount":18,"pages":[{"number":1623,"blocks":[{"type":"title","text":"333 巧应竞争对手"},{"type":"section","text":"Step1 场景词"},{"type":"entry","text":"competition mechanism 竞争机制","headword":"competition mechanism"},{"type":"entry","text":"positive competition 良性竞争","headword":"positive competition"},{"type":"entry","text":"unfair competition 不正当竞争","headword":"unfair competition"}]},{"number":1624,"blocks":[{"type":"entry","text":"anti-unfair competition 反不正当竞争","headword":"anti-unfair competition"},{"type":"entry","text":"face intense competition 面临激烈的竞争","headword":"face intense competition"},{"type":"entry","text":"anti-monopoly [ˌænti məˈnɒpəli]","headword":"anti-monopoly"},{"type":"definition","text":"n.反垄断"},{"type":"entry","text":"dominate exclusively 独霸","headword":"dominate exclusively"},{"type":"entry","text":"dumping [ˈdʌmpɪŋ]","headword":"dumping"},{"type":"definition","text":"n.倾销"},{"type":"entry","text":"anti-dumping [ˌænti ˈdʌmpɪŋ]","headword":"anti-dumping"},{"type":"definition","text":"n.反倾销"},{"type":"entry","text":"under threat 受到威胁","headword":"under threat"}]},{"number":1625,"blocks":[{"type":"entry","text":"price war 价格战","headword":"price war"},{"type":"entry","text":"at the sale 打折","headword":"at the sale"},{"type":"entry","text":"sales promotion 促销","headword":"sales promotion"},{"type":"entry","text":"steal [stiːl]","headword":"steal"},{"type":"definition","text":"n./v.窃取，偷窃"}]},{"number":1626,"blocks":[{"type":"note","text":"◎steal away偷走"},{"type":"entry","text":"trade secret 商业机密","headword":"trade secret"},{"type":"entry","text":"piracy [ˈpaɪrəsi]","headword":"piracy"},{"type":"definition","text":"n.盗用"},{"type":"entry","text":"profit [ˈprɒfɪt]","headword":"profit"},{"type":"definition","text":"n.利润"},{"type":"definition","text":"v.获利"},{"type":"note","text":"◎profit from得益于…；利用"},{"type":"section","text":"Step2 学以致用"}]},{"number":1627,"blocks":[{"type":"section","text":"Conversation 1"},{"type":"example","text":"A：You must be able to compete with your rival firms.（你必须能够"},{"type":"text","text":"与你的对手公司竞争。）"},{"type":"example","text":"B：Yes, we have talked about this. （是的，我们已经讨论过这件事"},{"type":"text","text":"了。）"},{"type":"section","text":"Conversation 2"},{"type":"example","text":"A：Do I get a discount if I have a Golden Card? （如果我有金卡，"},{"type":"text","text":"可以有优惠吗？）"},{"type":"example","text":"B：Actually yes. We’ll take 10% off. （实际上是的。我们可以给你"},{"type":"text","text":"打九折。）"}]}]}
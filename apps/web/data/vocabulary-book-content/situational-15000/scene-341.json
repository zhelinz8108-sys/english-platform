{"schemaVersion":1,"bookId":"situational-15000","unitId":"scene-341","title":"装船运输","sectionId":"chapter-15","sectionTitle":"商务经济全在行","pageStart":1658,"pageEnd":1662,"extractionMethod":"text-layer","wordEntryCount":20,"duplicateEntryCount":18,"pages":[{"number":1658,"blocks":[{"type":"title","text":"341 装船运输"},{"type":"section","text":"Step1 场景词"},{"type":"entry","text":"shipping order 装货单","headword":"shipping order"},{"type":"entry","text":"shipping advice 装运通知","headword":"shipping advice"},{"type":"entry","text":"lading [ˈleɪdɪŋ]","headword":"lading"},{"type":"definition","text":"n.装船"},{"type":"entry","text":"load with 装载某物","headword":"load with"},{"type":"entry","text":"port dues 港口税，口岸税","headword":"port dues"}]},{"number":1659,"blocks":[{"type":"entry","text":"cost and freight 成本加运费价","headword":"cost and freight"},{"type":"entry","text":"weight ton 重量吨（即货物收费以重量计费）","headword":"weight ton"},{"type":"entry","text":"measurement ton 容积吨（即货物收费以容积计费）","headword":"measurement ton"},{"type":"entry","text":"landing charge 卸货费，上岸费","headword":"landing charge"},{"type":"entry","text":"discharge of 卸下","headword":"discharge of"},{"type":"entry","text":"bill of lading 提货单","headword":"bill of lading"},{"type":"note","text":"◎master bill of lading主提单"},{"type":"entry","text":"ocean bill of lading海运提单","headword":"ocean bill of lading"}]},{"number":1660,"blocks":[{"type":"entry","text":"physical distribution 物资调运","headword":"physical distribution"},{"type":"entry","text":"long haul 长途运输","headword":"long haul"},{"type":"entry","text":"short-distance freight 短途货运","headword":"short-distance freight"},{"type":"entry","text":"full container load 整箱货","headword":"full container load"},{"type":"entry","text":"less-than-container load 拼箱货（散货）","headword":"less-than-container load"},{"type":"entry","text":"container freight station 集装箱货运站","headword":"container freight station"},{"type":"entry","text":"cargo receipt 承运货物收据","headword":"cargo receipt"}]},{"number":1661,"blocks":[{"type":"entry","text":"timely [ˈtaɪmli]","headword":"timely"},{"type":"definition","text":"a.及时的，适时的"},{"type":"note","text":"◎timely adjustment适时调节"},{"type":"section","text":"Step2 学以致用"},{"type":"section","text":"Conversation 1"},{"type":"example","text":"A：I need to find a freight forwarder. Do you have any suggestions?"},{"type":"text","text":"（我需要找一家货运代理。你有什么建议吗？）"},{"type":"example","text":"B：Actually, we've got a freight forwarder. （实际上，我们找到货"},{"type":"text","text":"运代理了。）"}]},{"number":1662,"blocks":[{"type":"section","text":"Conversation 2"},{"type":"example","text":"A：The goods have been consigned to you. （货物已交付给你。）"},{"type":"example","text":"B：Yes. （是的。）"}]}]}
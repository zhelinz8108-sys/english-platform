{"schemaVersion":1,"bookId":"situational-15000","unitId":"scene-345","title":"计算收益","sectionId":"chapter-15","sectionTitle":"商务经济全在行","pageStart":1679,"pageEnd":1682,"extractionMethod":"text-layer","wordEntryCount":25,"duplicateEntryCount":8,"pages":[{"number":1679,"blocks":[{"type":"title","text":"345 计算收益"},{"type":"section","text":"Step1 场景词"},{"type":"entry","text":"net profit 净利润","headword":"net profit"},{"type":"entry","text":"boost profit 提高利润","headword":"boost profit"},{"type":"entry","text":"turnover [ˈtɜːnəʊvə(r)]","headword":"turnover"},{"type":"definition","text":"n.营业额"},{"type":"note","text":"◎turnover tax营业税"},{"type":"entry","text":"aboriginal cost 原始成本","headword":"aboriginal cost"},{"type":"entry","text":"fixed capital 固定资本","headword":"fixed capital"},{"type":"entry","text":"average cost 平均成本","headword":"average cost"},{"type":"entry","text":"total cost 总成本","headword":"total cost"}]},{"number":1680,"blocks":[{"type":"entry","text":"overhead [ˈəʊvəhed]","headword":"overhead"},{"type":"definition","text":"n.企业经常性支出"},{"type":"note","text":"◎overhead expense管理费用；营业间接成本"},{"type":"entry","text":"budget plan 预算方案","headword":"budget plan"},{"type":"entry","text":"overall budget 总体预算","headword":"overall budget"},{"type":"entry","text":"earnings ratio 收益率","headword":"earnings ratio"},{"type":"entry","text":"rate of return 盈利率","headword":"rate of return"},{"type":"entry","text":"nominal yield 名义收益率","headword":"nominal yield"},{"type":"entry","text":"current yield 现时收益率","headword":"current yield"},{"type":"entry","text":"average yield 平均收益率","headword":"average yield"},{"type":"entry","text":"income expectation 收益预期","headword":"income expectation"},{"type":"entry","text":"constant return 固定收益","headword":"constant return"},{"type":"entry","text":"return on an investment 一项投资的回报","headword":"return on an investment"},{"type":"entry","text":"computational formula 计算公式","headword":"computational formula"}]},{"number":1681,"blocks":[{"type":"entry","
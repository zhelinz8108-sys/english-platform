{"schemaVersion":1,"bookId":"situational-15000","unitId":"scene-347","title":"双方协商","sectionId":"chapter-15","sectionTitle":"商务经济全在行","pageStart":1688,"pageEnd":1692,"extractionMethod":"text-layer","wordEntryCount":14,"duplicateEntryCount":20,"pages":[{"number":1688,"blocks":[{"type":"title","text":"347 双方协商"},{"type":"section","text":"Step1 场景词"},{"type":"entry","text":"trade partner 贸易伙伴","headword":"trade partner"},{"type":"entry","text":"trade partnership 贸易伙伴关系","headword":"trade partnership"},{"type":"entry","text":"internal strife 内讧","headword":"internal strife"},{"type":"entry","text":"dealing [ˈdiːlɪŋ]","headword":"dealing"},{"type":"definition","text":"n.交易"},{"type":"note","text":"◎exclusive dealing独家销售"}]},{"number":1689,"blocks":[{"type":"entry","text":"uncooperative [ˌʌnkəʊˈɒpərətɪv]","headword":"uncooperative"},{"type":"definition","text":"a.不愿合作的"},{"type":"note","text":"◎uncooperative attitude不合作态度"}]},{"number":1690,"blocks":[{"type":"entry","text":"coordinator [kəʊˈɔːdɪneɪtə(r)]","headword":"coordinator"},{"type":"definition","text":"n.协调者"},{"type":"entry","text":"coordinate mechanism 协调机制","headword":"coordinate mechanism"}]},{"number":1691,"blocks":[{"type":"entry","text":"price difference 差价","headword":"price difference"},{"type":"entry","text":"drawback [ˈdrɔːbæk]","headword":"drawback"},{"type":"definition","text":"n.退税"},{"type":"entry","text":"reach an agreement 达成一致","headword":"reach an agreement"},{"type":"entry","text":"content with 对…感到满意","headword":"content with"},{"type":"entry","text":"win-win [ˌwɪn ˈwɪn]","headword":"win-win"},{"type":"definition","text":"a.双赢的"},{"type":"entry","text":"rely on 依靠；信任","headword":"rely on"},{"type":"entry","text":"time limit 时间限制","headword":"time limit"},{"type":"section","text":"Step2 学以致用"}]},{"number":1692,"blocks":[{"type":"section","text":"Conversation 1"},{"type":"example","text":"A：Does your country have a drawback system? （你们国家实行退"},{"type":"text","text":"税制度吗？）"},{"type":"example","tex
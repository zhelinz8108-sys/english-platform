nition","text":"n.小兔子"},{"type":"entry","text":"rat [ræt]","headword":"rat"},{"type":"definition","text":"n.鼠"},{"type":"note","text":"◎brown rat褐鼠/dirty rat卑鄙的人"},{"type":"entry","text":"guinea pig 豚鼠","headword":"guinea pig"},{"type":"entry","text":"vole [vəʊl]","headword":"vole"},{"type":"definition","text":"n.田鼠"},{"type":"entry","text":"dormouse [ˈdɔːmaʊs]","headword":"dormouse"},{"type":"definition","text":"n.睡鼠"},{"type":"entry","text":"marmot [ˈmɑːmət]","headword":"marmot"},{"type":"definition","text":"n.土拨鼠"}]},{"number":1866,"blocks":[{"type":"entry","text":"insectivore [ɪnˈsektɪvɔː(r)]","headword":"insectivore"},{"type":"definition","text":"n.食虫动物"},{"type":"entry","text":"hedgehog [ˈhedʒhɒɡ]","headword":"hedgehog"},{"type":"definition","text":"n.刺猬"},{"type":"entry","text":"anteater [ˈæntiːtə(r)]","headword":"anteater"},{"type":"definition","text":"n.食蚁兽"},{"type":"entry","text":"backbone [ˈbækbəʊn]","headword":"backbone"},{"type":"definition","text":"n.脊椎"},{"type":"entry","text":"homeotherm [ˈhɒmiəθɜːm]","headword":"homeotherm"},{"type":"definition","text":"n.恒温动物"},{"type":"entry","text":"viviparity [ˌvɪvɪˈpærəti]","headword":"viviparity"},{"type":"definition","text":"n.胎生"},{"type":"entry","text":"leap [liːp]","headword":"leap"},{"type":"definition","text":"n./v.跳，跳跃"}]},{"number":1867,"blocks":[{"type":"note","text":"◎leap into跳进/leap a stream跃过小溪"},{"type":"entry","text":"blow a horn吹号角","headword":"blow a horn"},{"type":"entry","text":"bestial [ˈbestiəl]","headword":"bestial"},{"type":"definition","text":"a.野兽的，残忍的，卑劣的"},{"type":"section","text":"Step2 学以致用"},{"type":"text","text":"有趣的小词pig"},{"type":"text","text":"Let's pig out. 让我们大吃一顿吧。"},{"type":"text","text":"看来不论中外都一致公认“猪”是一种食量颇大的动物，不过中文"},{"type":"text","text":"里说“狼吞虎咽”，英文中却说pig out，当然意思相近，而且还很形象"},{"type":"text","text":"呢！除了pig之外，hog也能表示猪，比如I can eat a hog，这个hog指的"},{"type":"text","text":"是那种专门养来供人食用的大猪，所以你一餐能吃下一头猪，表示你"},{"type":"text","text":"的确是饿了。"}]}]}
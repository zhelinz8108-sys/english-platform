{"schemaVersion":1,"bookId":"situational-15000","unitId":"scene-443","title":"出庭做证","sectionId":"chapter-20","sectionTitle":"依法办事不出错","pageStart":2181,"pageEnd":2185,"extractionMethod":"text-layer","wordEntryCount":22,"duplicateEntryCount":18,"pages":[{"number":2181,"blocks":[{"type":"title","text":"443 出庭做证"},{"type":"section","text":"Step1 场景词"},{"type":"entry","text":"forensic medicine法医学","headword":"forensic medicine"},{"type":"entry","text":"forensic accounting法务会计学","headword":"forensic accounting"},{"type":"entry","text":"eyewitness [ˈaɪwɪtnəs]","headword":"eyewitness"},{"type":"definition","text":"n.目击者；见证人"},{"type":"note","text":"◎eyewitness account目击人的叙述"},{"type":"entry","text":"witness [ˈwɪtnəs]","headword":"witness"},{"type":"definition","text":"n.（法庭上的）证人"},{"type":"note","text":"◎material witness重要证人"},{"type":"entry","text":"tainted witness污点证人","headword":"tainted witness"}]},{"number":2182,"blocks":[{"type":"entry","text":"certify [ˈsɜːtɪfaɪ]","headword":"certify"},{"type":"definition","text":"v.（尤指书面）证明"},{"type":"entry","text":"proof [pruːf]","headword":"proof"},{"type":"definition","text":"n.证据，证物，证言"},{"type":"note","text":"◎written proof书面证明"},{"type":"entry","text":"abundant proof充足的证据","headword":"abundant proof"}]},{"number":2183,"blocks":[{"type":"entry","text":"circumstantial evidence 旁证，间接证据","headword":"circumstantial evidence"},{"type":"entry","text":"admitted evidence 采信的证据","headword":"admitted evidence"},{"type":"entry","text":"material evidence 物证","headword":"material evidence"},{"type":"entry","text":"substantial evidence 实（质）体证据","headword":"substantial evidence"},{"type":"entry","text":"tangible evidence 实物证据","headword":"tangible evidence"},{"type":"entry","text":"real evidence 实物证据","headword":"real evidence"},{"type":"entry","text":"demonstrative evidence 示意证据","headword":"demonstrative evidence"},{"type":"entry","text":"audio-visual evidence 视听证据","headword":"audio-visual evidence"},{"type":"entry","text":"verbal evidence 言词证据","headword":"verbal evidence"},{"type":"entry","text":"cross-examination 交互讯问；盘问","headword":"cross-examination"},{"type":"entry","text":"eyewitness identification 目击证人辨认","headword":"eyewitness identification"}]},{"number":2184,"blocks":[{"type":"entry","text":"circumlocution [ˌsɜːkəmləˈkjuːʃn]","headword":"circumlocution"},{"type":"definition","text":"n.迂回累赘的陈述；遁词"},{"type":"entry","text":"provable [ˈpruːvəbl]","headword":"provable"},{"type":"definition","text":"a.可证明的，可查明的"},{"type":"note","text":"◎provable cause合理的根据；可能的原因"},{"type":"entry","text":"proved [ˈpruːvd]","headword":"proved"},{"type":"definition","text":"a.证实的，被证明的"},{"type":"note","text":"◎proved fact被证实的事实"}]},{"number":2185,"blocks":[{"type":"section","text":"Step2 学以致用"},{"type":"section","text":"Conversation 1"},{"type":"example","text":"A：Has he gone to the court? （他去法庭了吗？）"},{"type":"example","text":"B：I think he hasn't. The media is banned from the hearing. （我想他"},{"type":"text","text":"没去。媒体被禁止出席审讯。）"},{"type":"section","text":"Conversation 2"},{"type":"example","text":"A：Why was he arrested? （他为什么被逮捕了？）"},{"type":"example","text":"B：Because he was accused of murder. （因为他被指控犯有谋杀"},{"type":"text","text":"罪。）"}]}]}
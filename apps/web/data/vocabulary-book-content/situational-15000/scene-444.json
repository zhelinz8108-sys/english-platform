{"schemaVersion":1,"bookId":"situational-15000","unitId":"scene-444","title":"被告辩护","sectionId":"chapter-20","sectionTitle":"依法办事不出错","pageStart":2186,"pageEnd":2190,"extractionMethod":"text-layer","wordEntryCount":18,"duplicateEntryCount":19,"pages":[{"number":2186,"blocks":[{"type":"title","text":"444 被告辩护"},{"type":"section","text":"Step1 场景词"},{"type":"entry","text":"defend [dɪˈfend]","headword":"defend"},{"type":"definition","text":"v.辩护"},{"type":"entry","text":"defence evidence辩护证据","headword":"defence evidence"},{"type":"entry","text":"affirmative defence 积极抗辩","headword":"affirmative defence"},{"type":"entry","text":"defender [dɪˈfendə(r)]","headword":"defender"},{"type":"definition","text":"n.辩护人"},{"type":"entry","text":"plea [pliː]","headword":"plea"},{"type":"definition","text":"n.（法庭中被告一方的）抗辩；答辩；辩护"},{"type":"note","text":"◎plea bargain认罪协议"},{"type":"entry","text":"plea agreement辩诉协议","headword":"plea agreement"},{"type":"entry","text":"written plea答辩书","headword":"written plea"}]},{"number":2187,"blocks":[{"type":"entry","text":"understatement [ˈʌndəsteɪtmənt]","headword":"understatement"},{"type":"definition","text":"n.不充分的陈述"},{"type":"entry","text":"burden of proof 举证责任","headword":"burden of proof"},{"type":"entry","text":"justifiable sentence合法判决","headword":"justifiable sentence"}]},{"number":2188,"blocks":[{"type":"entry","text":"justifiable homicide 自卫杀人","headword":"justifiable homicide"},{"type":"entry","text":"acquittal [əˈkwɪtl]","headword":"acquittal"},{"type":"definition","text":"n.宣告无罪，无罪的判决"}]},{"number":2189,"blocks":[{"type":"entry","text":"entrap [ɪnˈtræp]","headword":"entrap"},{"type":"definition","text":"v.使陷入"},{"type":"note","text":"◎entrap into使落入圈套"},{"type":"entry","text":"candidly [ˈkændɪdli]","headword":"candidly"},{"type":"definition","text":"ad.坦白地"},{"type":"entry","text":"candidly confess 供认不讳","headword":"candidly confess"},{"type":"entry","text":"alibi [ˈæləbaɪ]","headword":"alibi"},{"type":"definition","text":"n.不在犯罪现场的证明"},{"type":"entry","text":"winning party 胜诉方","headword":"winning party"},{"type":"entry","text":"losing party 败诉方","headword":"losing party"},{"type":"section","text":"Step2 学以致用"},{"type":"section","text":"Conversation 1"},{"type":"example","text":"A：I heard he was set free. （我听说他被释放了。）"}]},{"number":2190,"blocks":[{"type":"example","text":"B：Yes, it is proved that he is unspotted. （是的，他被证明是清白"},{"type":"text","text":"的。）"},{"type":"section","text":"Conversation 2"},{"type":"example","text":"A：The jury acquitted her, but I still think she's guilty.（陪审团宣判"},{"type":"text","text":"她无罪，但我仍认为她有罪。）"},{"type":"example","text":"B：Me too. （我也是。）"}]}]}
{
  "name": "@english/worker",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run src/reliability.integration.test.ts",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@english/shared": "workspace:*",
    "bullmq": "5.80.1",
    "dotenv": "17.4.2",
    "pg": "8.22.0",
    "pino": "10.3.1"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/pg": "8.20.0",
    "pino-pretty": "13.1.3",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}

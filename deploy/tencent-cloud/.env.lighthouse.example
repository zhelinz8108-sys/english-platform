# Never commit the real .env.lighthouse file.
SITE_DOMAIN=english.example.com
WEB_ORIGIN=https://english.example.com
PLATFORM_WEB_PORT=3100

IMAGE_TAG=lighthouse-2026-07-12.1
API_IMAGE=english-platform-api
WORKER_IMAGE=english-platform-worker
WEB_IMAGE=english-platform-web

# Literal container passwords. Generate three different values without URL syntax characters.
DB_OWNER_PASSWORD=REPLACE_WITH_RANDOM_OWNER_PASSWORD
APP_DB_PASSWORD=REPLACE_WITH_RANDOM_APP_PASSWORD
WORKER_DB_PASSWORD=REPLACE_WITH_RANDOM_WORKER_PASSWORD

# The URL passwords below must be percent-encoded versions of the matching values above.
DATABASE_ADMIN_URL=postgresql://english_owner:URL_ENCODED_OWNER_PASSWORD@postgres:5432/english_platform
DATABASE_URL=postgresql://english_app:URL_ENCODED_APP_PASSWORD@postgres:5432/english_platform
WORKER_DATABASE_URL=postgresql://english_worker:URL_ENCODED_WORKER_PASSWORD@postgres:5432/english_platform
DATABASE_POOL_MAX=8
DATABASE_STATEMENT_TIMEOUT_MS=15000
REDIS_URL=redis://redis:6379

JWT_ACCESS_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS
CSRF_SECRET=REPLACE_WITH_A_DIFFERENT_32_CHARACTER_SECRET
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
COOKIE_SECURE=true
COOKIE_DOMAIN=

# Private Tencent COS bucket. Bucket includes the APPID suffix.
S3_ENDPOINT=https://cos.ap-shanghai.myqcloud.com
S3_PUBLIC_ENDPOINT=https://cos.ap-shanghai.myqcloud.com
S3_REGION=ap-shanghai
S3_BUCKET=english-platform-private-1250000000
S3_ACCESS_KEY=REPLACE_WITH_LIMITED_CAM_SECRET_ID
S3_SECRET_KEY=REPLACE_WITH_LIMITED_CAM_SECRET_KEY
S3_FORCE_PATH_STYLE=false

SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_SERVICE_NAME=english-platform-api

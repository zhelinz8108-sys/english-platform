# Never commit the real .env.production file.
SITE_DOMAIN=learn.example.com
ACME_EMAIL=ops@example.com
WEB_ORIGIN=https://learn.example.com

# Optional immutable image locations. Defaults build locally on the CVM.
IMAGE_TAG=2026-07-12.1
API_IMAGE=english-platform-api
WORKER_IMAGE=english-platform-worker
WEB_IMAGE=english-platform-web

# TencentDB for PostgreSQL accounts must keep these exact role names:
# english_owner, english_app and english_worker.
DATABASE_ADMIN_URL=postgresql://english_owner:URL_ENCODED_PASSWORD@10.0.0.10:5432/english_platform
DATABASE_URL=postgresql://english_app:URL_ENCODED_PASSWORD@10.0.0.10:5432/english_platform
WORKER_DATABASE_URL=postgresql://english_worker:URL_ENCODED_PASSWORD@10.0.0.10:5432/english_platform
DATABASE_POOL_MAX=20
DATABASE_STATEMENT_TIMEOUT_MS=15000

# Use the VPC address. Keep Redis off the public internet and set noeviction.
REDIS_URL=redis://:URL_ENCODED_PASSWORD@10.0.0.20:6379
WORKER_CONCURRENCY=8
OUTBOX_BATCH_SIZE=50
OUTBOX_POLL_MS=1000

# Generate independently, for example: openssl rand -base64 48
JWT_ACCESS_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARACTERS
CSRF_SECRET=REPLACE_WITH_A_DIFFERENT_32_CHARACTER_SECRET
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
COOKIE_SECURE=true
COOKIE_DOMAIN=

# COS uses an S3-compatible regional endpoint and virtual-hosted-style requests.
# Bucket must include the Tencent Cloud APPID suffix.
S3_ENDPOINT=https://cos.ap-shanghai.myqcloud.com
S3_PUBLIC_ENDPOINT=https://cos.ap-shanghai.myqcloud.com
S3_REGION=ap-shanghai
S3_BUCKET=english-platform-private-1250000000
S3_ACCESS_KEY=REPLACE_WITH_LIMITED_CAM_SECRET_ID
S3_SECRET_KEY=REPLACE_WITH_LIMITED_CAM_SECRET_KEY
S3_FORCE_PATH_STYLE=false

SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_SERVICE_NAME=english-platform-api

{
  "name": "@english/database",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "migrations",
    "seeds"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:security": "tsx ../../tests/security/database-security.ts",
    "migrate": "tsx src/cli/migrate.ts",
    "seed": "tsx src/cli/seed.ts",
    "reset": "tsx src/cli/reset.ts"
  },
  "dependencies": {
    "@node-rs/argon2": "2.0.2",
    "kysely": "0.29.3",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/pg": "8.20.0",
    "tsx": "4.23.0",
    "typescript": "7.0.2"
  }
}
